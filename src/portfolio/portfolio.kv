<PortfolioUI>:
    orientation: 'vertical'

    # Exchange selector row
    BoxLayout:
        orientation: 'horizontal'
        size_hint_y: 0.08
        padding: [20, 5]
        spacing: 10

        Label:
            text: 'Exchange:'
            size_hint_x: 0.1
            font_size: '14sp'
        
        Spinner:
            id: exchange_spinner
            text: 'BINANCE'
            values: ['BINANCE', 'KRAKEN']
            size_hint_x: 0.15
            on_text: root.switch_exchange(self.text.lower())
        
        Label:
            id: exchange_label
            text: 'Exchange: BINANCE'
            size_hint_x: 0.2
            font_size: '14sp'
        
        Label:
            id: exchange_health_label
            text: '[color=00ff00]●[/color]'
            markup: True
            size_hint_x: 0.05
            font_size: '20sp'
        
        Widget:
            size_hint_x: 0.5

    # Sizing for the labels at the top (USD and BTC saldo)
    BoxLayout:
        orientation: 'horizontal'
        size_hint_y: 0.1
        padding: [20, 10]
        spacing: 20

        Label:
            text: 'Saldo in USD:'
            size_hint_x: 0.2
        Label:
            id: saldo_usd_label
            text: '0.00 USD'
            font_size: '18sp'
            size_hint_x: 0.4

        Label:
            text: 'Saldo in BTC:'
            size_hint_x: 0.2
        Label:
            id: saldo_btc_label
            text: '0.00000000 BTC'
            font_size: '18sp'
            size_hint_x: 0.2
        Widget:
            size_hint_x: 0.2

    # Section for column headers
    BoxLayout:
        orientation: 'horizontal'
        size_hint_y: 0.05
        padding: [20, 10]  # Padding to create space around the list
        spacing: 20  # Adds space between elements inside the box

        Widget:
            size_hint_x: 0.05  # Spacer for expand/collapse button
        Label:
            text: 'Symbol'
            bold: True
            size_hint_x: 0.12
        Label:
            text: 'Buy Price'
            bold: True
            size_hint_x: 0.11
        Label:
            text: 'Quantity'
            bold: True
            size_hint_x: 0.11
        Label:
            text: 'Available'
            bold: True
            size_hint_x: 0.11
        Label:
            text: 'Locked'
            bold: True
            size_hint_x: 0.11
        Label:
            text: 'Price in USD'
            bold: True
            size_hint_x: 0.11
        Label:
            text: 'Total in USD'
            bold: True
            size_hint_x: 0.11
        Label:
            text: 'PnL'
            bold: True
            size_hint_x: 0.08
        Widget:
            size_hint_x: 0.09  # Spacer for action button (Sell), adjusted so total is exactly 1

    # Section for the coin list
    BoxLayout:
        orientation: 'horizontal'
        padding: [20, 10, 20, 10]  # Padding for left, top, right, bottom
        RecycleView:
            id: coin_list
            viewclass: 'CoinListItem'
            data: root.coin_list_data  # Bind the RecycleView's data to the ListProperty
            RecycleBoxLayout:
                default_size: None, dp(56)
                default_size_hint: 1, None
                size_hint_y: None
                height: self.minimum_height
                orientation: 'vertical'
