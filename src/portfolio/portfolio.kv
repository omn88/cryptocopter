<PortfolioUI>:
    orientation: 'vertical'

    # Sizing for the labels at the top (USDT and BTC saldo)
    BoxLayout:
        orientation: 'horizontal'
        size_hint_y: 0.1
        padding: [20, 10]
        spacing: 20

        Label:
            text: 'Saldo in USDT:'
            size_hint_x: 0.2
        Label:
            id: saldo_usdt_label
            text: '0.00 USDT'
            font_size: '18sp'
            size_hint_x: 0.4

        Label:
            text: 'Saldo in BTC:'
            size_hint_x: 0.2
        Label:
            id: saldo_btc_label
            text: '0.00000000 BTC'
            font_size: '18sp'
            size_hint_x: 0.4

    # Section for column headers
    BoxLayout:
        orientation: 'horizontal'
        size_hint_y: 0.05
        padding: [20, 10]  # Padding to create space around the list
        spacing: 20  # Adds space between elements inside the box

        Label:
            text: 'Symbol'
            bold: True
            size_hint_x: 0.15  # Adjust the width for each label
        Label:
            text: 'Quantity'
            bold: True
            size_hint_x: 0.2
        Label:
            text: 'Price in USDT'
            bold: True
            size_hint_x: 0.2
        Label:
            text: 'Total in USDT'
            bold: True
            size_hint_x: 0.25

    # Section for the coin list
    BoxLayout:
        orientation: 'horizontal'
        padding: [20, 10, 20, 10]  # Padding for left, top, right, bottom
        RecycleView:
            id: coin_list
            viewclass: 'CoinListItem'
            data: root.coin_list_data  # Bind the RecycleView's data to the ListProperty
            RecycleBoxLayout:
                default_size: None, dp(56)
                default_size_hint: 1, None
                size_hint_y: None
                height: self.minimum_height
                orientation: 'vertical'
