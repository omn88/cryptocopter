<HPListItem@BoxLayout>:
    orientation: 'horizontal'
    size_hint_y: None
    height: '40dp'
    padding: [5, 5]
    spacing: 10

    canvas.before:
        Color:
            rgba: 0.2, 0.2, 0.2, 1  # Define the background color for the rows
        Rectangle:
            size: self.size
            pos: self.pos
        Color:
            rgba: 1, 1, 1, 0.2  # Define a border-like separator for the rows
        Line:
            points: [self.x, self.y, self.right, self.y]  # Add a line at the bottom
            width: 1.2

    hp_id: ''
    asset: ''
    buy_price: ''
    quantity: ''
    quantity_usdt: ''
    current_price: ''
    net: ''
    net_percent: ''
    sell_price: ''
    expected_return: ''
    state: ''

    Label:
        text: root.hp_id
        size_hint_x: 0.05
        font_size: '14sp'

    Label:
        text: root.asset
        size_hint_x: 0.05
        font_size: '14sp'

    Label:
        text: root.buy_price
        size_hint_x: 0.1
        font_size: '14sp'

    Label:
        text: root.quantity
        size_hint_x: 0.05
        font_size: '14sp'

    Label:
        text: root.quantity_usdt
        size_hint_x: 0.1
        font_size: '14sp'

    Label:
        text: root.current_price
        size_hint_x: 0.1
        font_size: '14sp'

    Label:
        text: root.net
        size_hint_x: 0.1
        font_size: '14sp'

    Label:
        text: root.net_percent
        size_hint_x: 0.05
        font_size: '14sp'

    Label:
        text: root.sell_price
        size_hint_x: 0.1
        font_size: '14sp'

    Label:
        text: root.expected_return
        size_hint_x: 0.1
        font_size: '14sp'

    Label:
        text: root.state
        size_hint_x: 0.1
        font_size: '14sp'

    Button:
        id: action_button
        text: "SELL HP" if root.sell_price == "0.0" else "CANCEL"
        size_hint_x: 0.1
        on_release:
            if root.sell_price == "0.0": root.hp_manager.sell_hp_button(root.hp_id, root.asset, root.quantity, root.buy_price)
            else: root.hp_manager.cancel_sell(root.hp_id, root.asset)
        disabled: root.state == "SOLD"