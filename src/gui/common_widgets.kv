<CoinListItem@BoxLayout>:
    orientation: "horizontal"
    size_hint_y: None
    height: '30dp'

    symbol: ''
    quantity: ''
    price_usd: ''
    total_usd: ''

    canvas.before:
        Color:
            rgba: 1, 1, 1, 0.1  # Line under each item
        Line:
            points: [self.x, self.y, self.x + self.width, self.y]

    Label:
        text: root.symbol
        size_hint_x: 0.2
    Label:
        text: root.quantity
        size_hint_x: 0.2
    Label:
        text: root.price_usd
        size_hint_x: 0.3
    Label:
        text: root.total_usd
        size_hint_x: 0.3

<HPListItem@BoxLayout>:
    orientation: 'horizontal'
    size_hint_y: None
    height: '40dp'
    padding: [5, 5]
    spacing: 10

    canvas.before:
        Color:
            rgba: (0.15, 0.15, 0.15, 1) if root.is_child else (0.2, 0.2, 0.2, 1)  # Darker background for child items
        Rectangle:
            size: self.size
            pos: self.pos
        Color:
            rgba: 1, 1, 1, 0.2  # Define a border-like separator for the rows
        Line:
            points: [self.x, self.y, self.right, self.y]  # Add a line at the bottom
            width: 1.2

    hp_id: ''
    coin: ''
    buy_price: ''
    quantity: ''
    quantity_usd: ''
    current_price: ''
    net: ''
    net_percent: ''
    sell_price: ''
    expected_return: ''
    state: ''
    is_child: False
    has_children: False
    is_expanded: False

    # Indentation for child items and expand/collapse button for parents
    BoxLayout:
        Button:
            text: "▼" if root.is_expanded else "▶" if root.has_children else ""
            size_hint_x: 0.03
            width: 20 if root.has_children else 0
            opacity: 1 if root.has_children else 0
            background_color: (0.3, 0.3, 0.3, 1)
            on_release: root.hp_manager.toggle_hp_expansion(root.hp_id) if root.has_children else None

        Label:
            text: root.hp_id
            font_size: '14sp'
            size_hint_x: 0.07

        Label:
            text: root.coin
            size_hint_x: 0.12
            font_size: '14sp'

        Label:
            text: root.buy_price
            size_hint_x: 0.08
            font_size: '14sp'

        Label:
            text: root.quantity
            size_hint_x: 0.06
            font_size: '14sp'

        Label:
            text: root.quantity_usd
            size_hint_x: 0.08
            font_size: '14sp'

        Label:
            text: root.current_price
            size_hint_x: 0.08
            font_size: '14sp'

        Label:
            text: root.net
            size_hint_x: 0.10
            font_size: '14sp'
            color: (0.2, 0.8, 0.2, 1) if root.net and root.net != "0.0" and not root.net.startswith("-") else (0.8, 0.2, 0.2, 1) if root.net and root.net.startswith("-") else (1, 1, 1, 1)

        Label:
            text: root.net_percent + "%" if root.net_percent and root.net_percent != "0.0" else "0.0%"
            size_hint_x: 0.06
            font_size: '14sp'
            color: (0.2, 0.8, 0.2, 1) if root.net_percent and root.net_percent != "0.0" and not root.net_percent.startswith("-") else (0.8, 0.2, 0.2, 1) if root.net_percent and root.net_percent.startswith("-") else (1, 1, 1, 1)

        Label:
            text: root.sell_price
            size_hint_x: 0.08
            font_size: '14sp'

        Label:
            text: root.expected_return
            size_hint_x: 0.09
            font_size: '14sp'

        Label:
            text: root.state
            size_hint_x: 0.08
            font_size: '14sp'

        Button:
            id: action_button
            text: "SELL HP" if root.sell_price == "0.0" else "CANCEL"
            size_hint_x: 0.10
            on_release:
                if root.sell_price == "0.0": root.hp_manager.sell_hp_button(root.hp_id, root.coin, root.quantity, root.buy_price)
                else: root.hp_manager.cancel_sell(root.hp_id, root.coin)
            disabled: root.is_child or root.state == "SOLD"
