#:import dp kivy.metrics.dp

<CoinListItem@BoxLayout>:
    orientation: "vertical"
    size_hint_y: None
    height: self.minimum_height

    symbol: ''
    buy_price: ''
    quantity: ''
    available_qty: ''
    locked_qty: ''
    price_usd: ''
    total_usd: ''
    pnl: ''
    pnl_color: [1, 1, 1, 1]
    weighted_avg_buy_price: 0.0
    expanded: False
    lots: []
    is_lot_row: False
    has_lots: False
    portfolio_manager: None

    canvas.before:
        Color:
            rgba: (0.2, 0.2, 0.2, 0.3) if root.is_lot_row else (1, 1, 1, 0.1)  # Darker background for lot rows
        Rectangle:
            pos: self.pos
            size: self.size
        Color:
            rgba: 1, 1, 1, 0.1  # Line under each item
        Line:
            points: [self.x, self.y, self.x + self.width, self.y]

    # Parent row (summary for the coin)
    BoxLayout:
        orientation: 'horizontal'
        size_hint_y: None
        height: '30dp'

        Button:
            text: ('▼' if root.expanded else '▶') if (not root.is_lot_row and root.has_lots) else ''
            size_hint_x: 0.05
            on_press: root.portfolio_manager.toggle_expand_coin_item(root.symbol) if not root.is_lot_row and root.portfolio_manager and root.has_lots else None
            disabled: root.is_lot_row or not root.has_lots
            background_color: (1, 1, 1, 1) if (not root.is_lot_row and root.has_lots) else (0, 0, 0, 0)

        Label:
            text: root.symbol if root.symbol else '—'
            size_hint_x: 0.12
        Label:
            text: root.buy_price if root.buy_price else '—'
            size_hint_x: 0.11
        Label:
            text: root.quantity if root.quantity else '0.0'
            size_hint_x: 0.11
        Label:
            text: root.available_qty if root.available_qty else '0.0'
            size_hint_x: 0.11
        Label:
            text: root.locked_qty if root.locked_qty else '0.0'
            size_hint_x: 0.11
        Label:
            text: root.price_usd if root.price_usd else '0.0'
            size_hint_x: 0.11
        Label:
            text: root.total_usd if root.total_usd else '0.0'
            size_hint_x: 0.11
        Label:
            text: root.pnl if root.pnl else '—'
            color: root.pnl_color
            size_hint_x: 0.08
        Button:
            text: 'Sell'
            size_hint_x: 0.09
            on_press: root.portfolio_manager.sell_lot_button(root.symbol, root.available_qty, root.buy_price.replace('$', '')) if root.is_lot_row and root.portfolio_manager else (root.portfolio_manager.sell_parent_button(root.symbol) if root.portfolio_manager and not root.is_lot_row else None)

    # Expandable child rows (buy lots)
    BoxLayout:
        id: lots_box
        orientation: 'vertical'
        size_hint_y: None
        height: self.minimum_height if root.expanded else 0
        opacity: 1 if root.expanded else 0
        # Dynamically add child rows for each lot in root.lots in Python
