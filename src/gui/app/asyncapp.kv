TabbedPanel:
    id: root_tabbed_panel
    do_default_tab: False

    TabbedPanelItem:
        text: 'Configure'
        BoxLayout:
            orientation: 'vertical'

            BoxLayout:
                orientation: 'horizontal'
                size_hint_y: 0.1

                Spinner:
                    id: strategy_spinner
                    text: 'Choose Strategy'
                    values: ('HP Manager',)
                    size_hint: (0.2, 1)
                    on_text: app.on_strategy_change(self.text)

                BoxLayout:
                    size_hint_x: 0.25

                BoxLayout:
                    orientation: 'horizontal'
                    size_hint: (0.35, 1)

                    Button:
                        id: start_button
                        text: 'Start'
                        size_hint: (0.5, 1)
                        on_release: app.start_strategy()

                    Button:
                        id: cancel_button
                        text: 'Cancel'
                        size_hint: (0.5, 1)
                        on_press: app.cancel_all_strategies()

            BoxLayout:
                size_hint_y: 0.02  # Spacer at the top

            BoxLayout:
                orientation: 'horizontal'
                size_hint_y: 0.07
                id: dynamic_ui_container

            BoxLayout:
                size_hint_y: 0.08  # Spacer

            TabbedPanel:
                size_hint_y: 0.67
                do_default_tab: False

                TabbedPanelItem:
                    id: active_strategies_tab
                    text: 'Strategies'
                    size_hint_x: None
                    width: 800

                    BoxLayout:
                        orientation: "vertical"

                TabbedPanelItem:
                    id: closed_strategies_tab
                    text: 'History'
                    size_hint_x: None
                    width: 800

                    BoxLayout:
                        orientation: "vertical"