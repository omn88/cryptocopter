TabbedPanel:
    id: root_tabbed_panel
    do_default_tab: False

    TabbedPanelItem:
        text: 'Configure'
        BoxLayout:
            orientation: 'vertical'

            BoxLayout:
                orientation: 'horizontal'
                size_hint_y: 0.1

                Spinner:
                    id: strategy_spinner
                    text: 'Choose Strategy'
                    values: ('HP Manager', 'RSI Basic', 'RSI Extended', 'RSI Special')
                    size_hint: (0.2, 1)
                    on_text: app.on_strategy_change(self.text)

                BoxLayout:
                    size_hint_x: 0.25

                BoxLayout:
                    orientation: 'horizontal'
                    size_hint: (0.35, 1)

                    Button:
                        id: start_button
                        text: 'Start'
                        size_hint: (0.5, 1)
                        on_release: app.start_strategy()

                    Button:
                        id: cancel_button
                        text: 'Cancel'
                        size_hint: (0.5, 1)
                        on_press: app.cancel_all_strategies()

            BoxLayout:
                size_hint_y: 0.02  # Spacer at the top

            BoxLayout:
                orientation: 'horizontal'
                size_hint_y: 0.07
                id: dynamic_ui_container

            BoxLayout:
                size_hint_y: 0.08  # Spacer

            TabbedPanel:
                size_hint_y: 0.67
                do_default_tab: False

                TabbedPanelItem:
                    id: active_strategies_tab
                    text: 'Strategies'
                    size_hint_x: None
                    width: 800

                    BoxLayout:
                        orientation: "vertical"
                        BoxLayout:
                            size_hint_y: None
                            height: '30dp'
                            Label:
                                text: 'Strategy'
                            Label:
                                text: 'Symbol'
                            Label:
                                text: 'Leverage'
                            Label:
                                text: 'Quantity'
                            Label:
                                text: 'Entry Price'
                            Label:
                                text: 'Mark Price'
                            Label:
                                text: 'Liquidation Price'
                            Label:
                                text: 'Margin'
                            Label:
                                text: 'PnL'
                            Label:
                                text: 'State'
                        RecycleView:
                            id: active_strategies_list
                            data: app.active_strategies
                            viewclass: 'StrategyListItem'
                            RecycleBoxLayout:
                                default_size: None, dp(56)
                                default_size_hint: 1, None
                                size_hint_y: None
                                height: self.minimum_height
                                orientation: 'vertical'
                TabbedPanelItem:
                    id: closed_strategies_tab
                    text: 'History'
                    size_hint_x: None
                    width: 800

                    BoxLayout:
                        orientation: "vertical"
                        BoxLayout:
                            size_hint_y: None
                            height: '30dp'
                            Label:
                                text: 'Strategy'
                            Label:
                                text: 'Symbol'
                            Label:
                                text: 'Leverage'
                            Label:
                                text: 'Quantity'
                            Label:
                                text: 'Entry Price'
                            Label:
                                text: 'Mark Price'
                            Label:
                                text: 'Liquidation Price'
                            Label:
                                text: 'Margin'
                            Label:
                                text: 'PnL'
                            Label:
                                text: 'State'
                        RecycleView:
                            id: closed_strategies_list
                            data: app.closed_strategies
                            viewclass: 'StrategyListItem'
                            RecycleBoxLayout:
                                default_size: None, dp(56)
                                default_size_hint: 1, None
                                size_hint_y: None
                                height: self.minimum_height
                                orientation: 'vertical'

    TabbedPanelItem:
        text: 'Portfolio'
        BoxLayout:
            orientation: 'vertical'

            # Saldo section (this was described earlier)
            BoxLayout:
                orientation: 'horizontal'
                size_hint_y: 0.1
                padding: [20, 10]
                spacing: 20

                Label:
                    text: 'Saldo in USDT:'
                    size_hint_x: 0.2
                Label:
                    id: saldo_usdt_label
                    text: '0.00 USDT'
                    font_size: '18sp'
                    size_hint_x: 0.4

                Label:
                    text: 'Saldo in BTC:'
                    size_hint_x: 0.2
                Label:
                    id: saldo_btc_label
                    text: '0.00000000 BTC'
                    font_size: '18sp'
                    size_hint_x: 0.4

            # Coin list section
            BoxLayout:
                orientation: 'horizontal'
                size_hint_y: 0.05
                Label:
                    text: 'Symbol'
                Label:
                    text: 'Quantity'
                Label:
                    text: 'Price in USDT'
                Label:
                    text: 'Total in USDT'

            RecycleView:
                id: coin_list
                size_hint_y: 0.85
                viewclass: 'CoinListItem'
                RecycleBoxLayout:
                    default_size: None, dp(56)
                    default_size_hint: 1, None
                    size_hint_y: None
                    height: self.minimum_height
                    orientation: 'vertical'
