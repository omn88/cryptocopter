<HpManager>:
    file_name_input: file_name_input
    orientation: 'vertical'
    BoxLayout:
        orientation: 'vertical'
        size_hint_y: 0.35
        height: '150dp'  # Height for configuration controls

        BoxLayout:  # Main horizontal layout for configuration and buttons
            orientation: 'horizontal'

            BoxLayout:  # Configuration section (left side)
                orientation: 'vertical'
                size_hint_x: 1  # Using 60% of the horizontal space
                padding: [16, 0, 0, 0]

                BoxLayout:  # First line: Basic trading options
                    orientation: 'horizontal'
                    size_hint_y: 0.7
                    height: '50dp'
                    spacing: 5
                    BoxLayout:
                        id: symbol_container  # Placeholder for the SearchableDropDown
                        size_hint_x: 0.6
                        size_hint_y: 0.7  # Ensure this aligns with other elements
                    Spinner:
                        id: side_input
                        values: ['BUY', 'SELL']
                        text: 'SIDE'
                        size_hint_x: 0.15
                        size_hint_y: 0.9  # Full height within the line
                    Label:
                        text: 'budget: '
                        size_hint_x: 0.05
                        size_hint_y: 0.7  # Full height within the line
                    TextInput:
                        id: budget_input
                        text: '100'
                        multiline: False
                        input_filter: 'float'
                        size_hint_x: 0.15
                        size_hint_y: 0.6  # Full height within the line
                    BoxLayout:
                        size_hint_x: 0.05
                BoxLayout:  # Third line: Advanced trading options
                    orientation: 'horizontal'
                    size_hint_y: 0.3
                    height: '50dp'
                    Label:
                        text: 'Order Trigger(%):'
                        size_hint_x: 0.2
                        size_hint_y: 0.7  # Full height within the line
                    Spinner:
                        id: order_trigger_input
                        values: [str(round(x * 0.5, 1)) for x in range(0, 11)]  # Generates float values from 0.0 to 5.0 in 0.1 steps
                        text: '4.0'
                        size_hint_x: 0.1
                        size_hint_y: 0.6
                    Label:
                        text: 'Mode: '
                        size_hint_x: 0.1
                        size_hint_y: 0.7  # Full height within the line
                    Spinner:
                        id: mode_input
                        values: ['DCA', 'SINGLE']
                        text: 'SINGLE'
                        size_hint_x: 0.2
                        size_hint_y: 0.6  # Full height within the line
                    BoxLayout:
                        size_hint_x: 0.4

                #Empty space
                BoxLayout:
                    size_hint_y: 0.1
            # Empty space to fill 25% of the width
            BoxLayout:
                size_hint_x: 0.2

            # Right section for action buttons - maintains 25% width
            BoxLayout:
                orientation: 'vertical'
                size_hint_x: 0.2
                Button:
                    text: 'Add Record'
                    size_hint_y: None
                    height: '50dp'
                    on_release: root.trigger_add_record()

                Label:
                    id: validation_label
                    text: ''
                    color: 1, 0, 0, 1  # Red color for validation messages
                    size_hint_y: None
                    height: '30dp'

                # New TextInput for file name
                TextInput:
                    id: file_name_input
                    hint_text: 'Enter config file name'

                # New Save Button
                Button:
                    text: 'Save Config'
                    on_press: root.save_config()

                # New Load Button
                Button:
                    text: 'Load Config'
                    on_press: root.load_config()

    # Bottom section with tabbed panels for records
    TabbedPanel:
        do_default_tab: False
        size_hint_y: 0.65  # Allow this to take the remaining space

        TabbedPanelItem:
            text: 'Active'
            BoxLayout:
                orientation: 'vertical'
                BoxLayout:
                    size_hint_y: None
                    height: '40dp'
                    Spinner:
                        id: active_filter_input
                        text: 'All'
                        size_hint_x: 0.2
                        on_text: root.filter_records('active', self.text)
                    BoxLayout:
                        size_hint_x: 0.8  # Empty space for alignment
                BoxLayout:
                    size_hint_y: None
                    height: '30dp'
                    Label:
                        text: 'Open time'
                        size_hint_x: 0.13
                    Label:
                        text: 'Symbol'
                        size_hint_x: 0.08
                    Label:
                        text: 'Side'
                        size_hint_x: 0.05
                    Label:
                        text: 'Mode'
                        size_hint_x: 0.08
                    Label:
                        text: 'Price Low'
                        size_hint_x: 0.08
                    Label:
                        text: 'Price High'
                        size_hint_x: 0.08
                    Label:
                        text: 'Order Cancel'
                        size_hint_x: 0.1
                    Label:
                        text: 'Stagnation'
                        size_hint_x: 0.08
                    Label:
                        text: 'Current Price'
                        size_hint_x: 0.08
                    Label:
                        text: 'Budget'
                        size_hint_x: 0.06
                    Label:
                        text: 'Completeness'
                        size_hint_x: 0.08
                    Label:
                        text: ''
                        size_hint_x: 0.1
                RecycleView:
                    id: active_records_list
                    data: root.filtered_active_records
                    viewclass: 'RecordListItemActive'
                    RecycleBoxLayout:
                        default_size: None, dp(56)  # Adjust the height as necessary
                        default_size_hint: 1, None
                        size_hint_y: None
                        height: self.minimum_height  # This makes the layout as tall as its contents
                        orientation: 'vertical'

        TabbedPanelItem:
            text: 'Idle'
            BoxLayout:
                orientation: 'vertical'
                BoxLayout:
                    size_hint_y: None
                    height: '40dp'
                    Spinner:
                        id: idle_filter_input
                        text: 'All'
                        size_hint_x: 0.2
                        on_text: root.filter_records('idle', self.text)
                    BoxLayout:
                        size_hint_x: 0.8  # Empty space for alignment
                BoxLayout:
                    size_hint_y: None
                    height: '30dp'
                    Label:
                        text: 'Open Time'
                        size_hint_x: 0.13
                    Label:
                        text: 'Symbol'
                        size_hint_x: 0.08
                    Label:
                        text: 'Side'
                        size_hint_x: 0.05
                    Label:
                        text: 'Mode'
                        size_hint_x: 0.08
                    Label:
                        text: 'Price Low'
                        size_hint_x: 0.08
                    Label:
                        text: 'Price High'
                        size_hint_x: 0.08
                    Label:
                        text: 'Order Trigger'
                        size_hint_x: 0.1
                    Label:
                        text: 'Current Price'
                        size_hint_x: 0.1
                    Label:
                        text: 'Budget'
                        size_hint_x: 0.1
                    Label:
                        text: 'Completeness'
                        size_hint_x: 0.1
                    Label:
                        text: ''
                        size_hint_x: 0.1  # Space for the button
                RecycleView:
                    id: idle_records_list
                    data: root.filtered_idle_records
                    viewclass: 'RecordListItemIdle'
                    RecycleBoxLayout:
                        default_size: None, dp(56)  # Adjust the height as necessary
                        default_size_hint: 1, None
                        size_hint_y: None
                        height: self.minimum_height  # This makes the layout as tall as its contents
                        orientation: 'vertical'

        TabbedPanelItem:
            text: 'Archive'
            BoxLayout:
                orientation: 'vertical'
                BoxLayout:
                    size_hint_y: None
                    height: '40dp'
                    Spinner:
                        id: archive_filter_input
                        text: 'All'
                        size_hint_x: 0.2
                        on_text: root.filter_records('archive', self.text)
                    BoxLayout:
                        size_hint_x: 0.8  # Empty space for alignment
                BoxLayout:
                    size_hint_y: None
                    height: '30dp'
                    Label:
                        text: 'Open Time'
                        size_hint_x: 0.13
                    Label:
                        text: 'Close Time'
                        size_hint_x: 0.13
                    Label:
                        text: 'Symbol'
                        size_hint_x: 0.09
                    Label:
                        text: 'Side'
                        size_hint_x: 0.06
                    Label:
                        text: 'Mode'
                        size_hint_x: 0.09
                    Label:
                        text: 'Price Low'
                        size_hint_x: 0.1
                    Label:
                        text: 'Price High'
                        size_hint_x: 0.1
                    Label:
                        text: 'Order Trigger'
                        size_hint_x: 0.1
                    Label:
                        text: 'Budget'
                        size_hint_x: 0.1
                    Label:
                        text: 'Completeness'
                        size_hint_x: 0.1
                RecycleView:
                    id: archive_records_list
                    data: root.filtered_archive_records
                    viewclass: 'RecordListItemArchive'
                    RecycleBoxLayout:
                        default_size: None, dp(56)  # Adjust the height as necessary
                        default_size_hint: 1, None
                        size_hint_y: None
                        height: self.minimum_height  # This makes the layout as tall as its contents
                        orientation: 'vertical'

        TabbedPanelItem:
            text: 'Logs'
            ScrollView:
                scroll_type: ['bars', 'content']
                bar_width: 10
                effect_cls: 'ScrollEffect'  # To limit the scroll bounce effect
                TextInput:
                    id: log_display
                    on_parent: root.log_display = self
                    font_size: '14sp'
                    background_color: (0.2, 0.2, 0.2, 1)  # Shade of gray similar to the current prompt background
                    foreground_color: (1, 1, 1, 1)  # White text
                    padding: 10  # Padding inside TextInput
                    readonly: True
                    multiline: True
                    size_hint_y: None  # Allow the height to adjust dynamically
                    height: max(self.minimum_height, self.parent.height)  # Adjust height to the content or ScrollView's height
