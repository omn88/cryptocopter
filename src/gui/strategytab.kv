#:import SymbolMarkPrice src.gui.identifiers.futures.SymbolMarkPrice
#:import PnL src.gui.identifiers.futures.PnL
#:import ColorChangingQuantity src.gui.identifiers.futures.ColorChangingQuantity
#:import ColorChangingSide src.gui.identifiers.futures.ColorChangingSide

<StrategyTab>:
    orientation: 'vertical'
    BoxLayout:
        orientation: 'vertical'
        BoxLayout:
            id: top_section
            orientation: 'horizontal'
            size_hint_y: None
            height: '100dp'
            GridLayout:
                cols: 1
                size_hint_x: 0.8
                BoxLayout:
                    size_hint_y: None
                    height: '30dp'
                    Label:
                        text: "Strategy: " + root.strategy_name
                    Label:
                        text: "Symbol: " + root.symbol
                    Label:
                        text: "Price: " + root.price_label
            BoxLayout:
                size_hint_x: 0.2
                orientation: 'horizontal'
                Widget:
                    size_hint_x: 1
                Button:
                    text: "Cancel"
                    size_hint: None, None
                    width: '100dp'
                    height: self.width
                    on_release: root.on_cancel()

        BoxLayout:
            id: bottom_section
            orientation: 'horizontal'
            TabbedPanel:
                do_default_tab: False
                TabbedPanelItem:
                    text: 'Positions (' + str(root.position_count) + ')'
                    BoxLayout:
                        orientation: "vertical"
                        BoxLayout:
                            size_hint_y: None
                            height: '30dp'
                            Label:
                                text: 'Symbol'
                            Label:
                                text: 'Leverage'
                            Label:
                                text: 'Quantity'
                            Label:
                                text: 'Entry Price'
                            Label:
                                text: 'Mark Price'
                            Label:
                                text: 'Liquidation Price'
                            Label:
                                text: 'Margin'
                            Label:
                                text: 'PnL'
                            Label:
                                text: 'State'
                        RecycleView:
                            id: positions_list
                            data: root.open_positions
                            viewclass: 'PositionListItem'
                            RecycleBoxLayout:
                                default_size: None, dp(56)
                                default_size_hint: 1, None
                                size_hint_y: None
                                height: self.minimum_height
                                orientation: 'vertical'
                TabbedPanelItem:
                    text: 'Orders (' + str(root.order_count) + ')'
                    BoxLayout:
                        orientation: "vertical"
                        BoxLayout:
                            size_hint_y: None
                            height: '30dp'

                            canvas.before:
                                Color:
                                    rgba: 1, 1, 1, 0.1  # Change this to the color you want for the line
                                Line:
                                    points: [self.x, self.y, self.x + self.width, self.y]

                            Label:
                                text: 'Open Time'
                                size_hint_x: 0.15
                            Label:
                                text: 'Symbol'
                                size_hint_x: 0.11
                            Label:
                                text: 'Type'
                                size_hint_x: 0.10
                            Label:
                                text: 'Side'
                                size_hint_x: 0.08
                            Label:
                                text: 'Price'
                                size_hint_x: 0.08
                            Label:
                                text: 'Quantity'
                                size_hint_x: 0.09
                            Label:
                                text: 'Realized'
                                size_hint_x: 0.09
                            Label:
                                text: 'Status'
                                size_hint_x: 0.15
                            Label:
                                text: 'Order ID'
                                size_hint_x: 0.15
                        RecycleView:
                            id: orders_list
                            data: root.open_orders
                            viewclass: 'OrderListItem'
                            RecycleBoxLayout:
                                default_size: None, dp(56)
                                default_size_hint: 1, None
                                size_hint_y: None
                                height: self.minimum_height
                                orientation: 'vertical'
                TabbedPanelItem:
                    text: 'History O'
                    BoxLayout:
                        orientation: "vertical"
                        BoxLayout:
                            size_hint_y: None
                            height: '30dp'
                            Label:
                                text: 'Open Time'
                                size_hint_x: 0.15
                            Label:
                                text: 'Symbol'
                                size_hint_x: 0.11
                            Label:
                                text: 'Type'
                                size_hint_x: 0.10
                            Label:
                                text: 'Side'
                                size_hint_x: 0.08
                            Label:
                                text: 'Price'
                                size_hint_x: 0.08
                            Label:
                                text: 'Quantity'
                                size_hint_x: 0.09
                            Label:
                                text: 'Realized'
                                size_hint_x: 0.09
                            Label:
                                text: 'Status'
                                size_hint_x: 0.15
                            Label:
                                text: 'Order ID'
                                size_hint_x: 0.15
                        RecycleView:
                            id: history_list
                            data: root.closed_orders
                            viewclass: 'OrderListItem'
                            RecycleBoxLayout:
                                default_size: None, dp(56)
                                default_size_hint: 1, None
                                size_hint_y: None
                                height: self.minimum_height
                                orientation: 'vertical'
                TabbedPanelItem:
                    text: 'History P'
                    BoxLayout:
                        orientation: "vertical"
                        BoxLayout:
                            size_hint_y: None
                            height: '30dp'
                            Label:
                                text: 'Symbol'
                            Label:
                                text: 'Leverage'
                            Label:
                                text: 'Quantity'
                            Label:
                                text: 'Entry Price'
                            Label:
                                text: 'Mark Price'
                            Label:
                                text: 'Liquidation Price'
                            Label:
                                text: 'Margin'
                            Label:
                                text: 'PnL'
                            Label:
                                text: 'Status'
                        RecycleView:
                            id: positions_list
                            data: root.closed_positions
                            viewclass: 'PositionListItem'
                            RecycleBoxLayout:
                                default_size: None, dp(56)
                                default_size_hint: 1, None
                                size_hint_y: None
                                height: self.minimum_height
                                orientation: 'vertical'

                TabbedPanelItem:
                    text: 'Logs'
                    ScrollView:
                        scroll_type: ['bars', 'content']
                        bar_width: 10
                        effect_cls: 'ScrollEffect'  # To limit the scroll bounce effect
                        TextInput:
                            id: log_display
                            on_parent: root.log_display = self
                            font_size: '14sp'
                            background_color: (0.2, 0.2, 0.2, 1)  # Shade of gray similar to the current prompt background
                            foreground_color: (1, 1, 1, 1)  # White text
                            padding: 10  # Padding inside TextInput
                            readonly: True
                            multiline: True
                            size_hint_y: None  # Allow the height to adjust dynamically
                            height: max(self.minimum_height, self.parent.height)  # Adjust height to the content or ScrollView's height
