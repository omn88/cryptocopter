#:import HPManager src.gui.hp_manager.hp_manager.HPManager

<HpFront>:
    orientation: 'vertical'
    spacing: 10
    padding: [10, 10, 10, 10]

    # Header section with action buttons
    BoxLayout:
        orientation: 'horizontal'
        size_hint_y: None
        height: '60dp'
        spacing: 20
        padding: [20, 10, 20, 10]

        # Title
        Label:
            text: 'HP Manager'
            font_size: '18sp'
            bold: True
            size_hint_x: 0.4
            halign: 'left'
            valign: 'middle'
            text_size: self.size

        # Action buttons
        BoxLayout:
            orientation: 'horizontal'
            size_hint_x: 0.3
            spacing: 10

            Button:
                id: new_buy_hp_btn
                text: 'New Buy HP'
                size_hint_x: 0.5
                on_release: root.show_buy_modal()

            Button:
                id: new_sell_hp_btn
                text: 'New Sell HP'
                size_hint_x: 0.5
                on_release: root.show_sell_modal()

        # Filter controls
        BoxLayout:
            orientation: 'horizontal'
            size_hint_x: 0.3
            spacing: 10

            Label:
                text: 'Filter:'
                size_hint_x: None
                width: '50dp'
                halign: 'right'
                valign: 'middle'

            Spinner:
                id: hp_state_filter_spinner
                text: 'Active States (11)'
                size_hint_x: 0.7
                on_text: root.on_hp_state_filter_change(self.text)

            Button:
                text: 'Reset'
                size_hint_x: None
                width: '60dp'
                on_release: root.reset_hp_state_filter()

    # Header row for HP list
    BoxLayout:
        orientation: 'horizontal'
        size_hint_y: None
        height: '40dp'
        spacing: 2
        padding: [5, 5, 5, 5]
        canvas.before:
            Color:
                rgba: 0.3, 0.3, 0.3, 0.8
            Rectangle:
                pos: self.pos
                size: self.size

        # Expand column
        Label:
            text: ''
            size_hint_x: None
            width: '30dp'

        # Column headers
        Label:
            text: 'Type'
            size_hint_x: 0.08
            bold: True
            color: 1, 1, 1, 1

        Label:
            text: 'HP ID'
            size_hint_x: 0.1
            bold: True
            color: 1, 1, 1, 1

        Label:
            text: 'Coin'
            size_hint_x: 0.08
            bold: True
            color: 1, 1, 1, 1

        Label:
            text: 'Quantity'
            size_hint_x: 0.12
            bold: True
            color: 1, 1, 1, 1

        Label:
            text: 'Price'
            size_hint_x: 0.12
            bold: True
            color: 1, 1, 1, 1

        Label:
            text: 'Progress'
            size_hint_x: 0.1
            bold: True
            color: 1, 1, 1, 1

        Label:
            text: 'Net'
            size_hint_x: 0.12
            bold: True
            color: 1, 1, 1, 1

        Label:
            text: 'State'
            size_hint_x: 0.1
            bold: True
            color: 1, 1, 1, 1

        Label:
            text: 'Actions'
            size_hint_x: 0.18
            bold: True
            color: 1, 1, 1, 1

    # HP list content
    ScrollView:
        id: hp_list_scroll
        do_scroll_x: False
        bar_width: 10

        BoxLayout:
            id: hp_list_container
            orientation: 'vertical'
            size_hint_y: None
            height: self.minimum_height
            spacing: 1

            # Empty state (shown when no HP positions exist)
            Label:
                id: empty_state_label
                text: 'No HP positions yet. Click "New Buy HP" or "New Sell HP" to get started.'
                size_hint_y: None
                height: '100dp'
                halign: 'center'
                valign: 'middle'
                text_size: self.size
                color: 0.7, 0.7, 0.7, 1


# HP Row Widget Template
<HPRowWidget@BoxLayout>:
    orientation: 'horizontal'
    size_hint_y: None
    height: '40dp'
    spacing: 2
    padding: [5, 2, 5, 2]

    # Background styling based on row type
    canvas.before:
        Color:
            rgba: self.bg_color if hasattr(self, 'bg_color') else [0.2, 0.2, 0.2, 0.5]
        Rectangle:
            pos: self.pos
            size: self.size
        Color:
            rgba: 1, 1, 1, 0.1
        Line:
            points: [self.x, self.y, self.x + self.width, self.y]
            width: 1

    # Left padding for child rows
    Widget:
        size_hint_x: None
        width: self.parent.child_indent if hasattr(self.parent, 'child_indent') else 0

    # Expand/collapse button (for parent rows with children)
    Button:
        id: expand_btn
        text: '▼' if self.parent.is_expanded else '▶'
        size_hint_x: None
        width: '30dp' if self.parent.has_children else 0
        opacity: 1 if self.parent.has_children else 0
        disabled: not self.parent.has_children
        on_release: self.parent.toggle_expansion()

    # Data columns
    Label:
        id: type_label
        text: self.parent.position_type if hasattr(self.parent, 'position_type') else ''
        size_hint_x: 0.08
        halign: 'center'
        valign: 'middle'

    Label:
        id: hp_id_label
        text: self.parent.hp_id if hasattr(self.parent, 'hp_id') else ''
        size_hint_x: 0.1
        halign: 'center'
        valign: 'middle'

    Label:
        id: coin_label
        text: self.parent.coin if hasattr(self.parent, 'coin') else ''
        size_hint_x: 0.08
        halign: 'center'
        valign: 'middle'

    Label:
        id: quantity_label
        text: self.parent.quantity_display if hasattr(self.parent, 'quantity_display') else ''
        size_hint_x: 0.12
        halign: 'center'
        valign: 'middle'

    Label:
        id: price_label
        text: self.parent.price_display if hasattr(self.parent, 'price_display') else ''
        size_hint_x: 0.12
        halign: 'center'
        valign: 'middle'

    Label:
        id: progress_label
        text: self.parent.progress_display if hasattr(self.parent, 'progress_display') else ''
        size_hint_x: 0.1
        halign: 'center'
        valign: 'middle'

    Label:
        id: net_label
        text: self.parent.net_display if hasattr(self.parent, 'net_display') else ''
        size_hint_x: 0.12
        halign: 'center'
        valign: 'middle'

    Label:
        id: state_label
        text: self.parent.state_display if hasattr(self.parent, 'state_display') else ''
        size_hint_x: 0.1
        halign: 'center'
        valign: 'middle'

    # Action buttons
    BoxLayout:
        id: action_buttons
        orientation: 'horizontal'
        size_hint_x: 0.18
        spacing: 2

        Button:
            id: sell_btn
            text: 'Sell'
            size_hint_x: 0.5
            opacity: 1 if 'SELL' in (self.parent.action_buttons if hasattr(self.parent, 'action_buttons') else []) else 0
            disabled: 'SELL' not in (self.parent.action_buttons if hasattr(self.parent, 'action_buttons') else [])
            on_release: self.parent.on_action('sell') if hasattr(self.parent, 'on_action') else None

        Button:
            id: cancel_btn
            text: 'Cancel'
            size_hint_x: 0.5
            opacity: 1 if 'CANCEL' in (self.parent.action_buttons if hasattr(self.parent, 'action_buttons') else []) else 0
            disabled: 'CANCEL' not in (self.parent.action_buttons if hasattr(self.parent, 'action_buttons') else [])
            on_release: self.parent.on_action('cancel') if hasattr(self.parent, 'on_action') else None
