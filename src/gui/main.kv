TabbedPanel:
    id: root_tabbed_panel
    do_default_tab: False

    TabbedPanelItem:
        text: 'Configure'
        BoxLayout:
            orientation: 'vertical'

            BoxLayout:
                orientation: 'horizontal'
                size_hint_y: 0.07

                Spinner:
                    id: strategy_spinner
                    text: 'Choose Strategy'
                    values: ('RSI Basic', 'RSI Extended', 'RSI Special')
                    size_hint: (0.2, 1)
                    on_text: app.log_spinner_change('strategy', self.text)

                Spinner:
                    id: symbol_spinner
                    text: 'Choose Symbol'
                    values: ('BTCUSDT', 'ETHUSDT', 'ETHBTC')
                    size_hint: (0.2, 1)
                    on_text: app.log_spinner_change('symbol', self.text)

                BoxLayout:
                    size_hint_x: 0.25

                BoxLayout:
                    orientation: 'horizontal'
                    size_hint: (0.35, 1)

                    Button:
                        id: start_button
                        text: 'Start'
                        size_hint: (0.5, 1)
                        on_press: app.on_start_strategy()

                    Button:
                        id: cancel_button
                        text: 'Cancel'
                        size_hint: (0.5, 1)
                        on_press: app.on_cancel()

            Label:
                size_hint_y: 0.1
                text: ''

            TabbedPanel:
                size_hint_y: 0.67
                do_default_tab: False

                TabbedPanelItem:
                    text: 'Strategies'
                    size_hint_x: None
                    width: 800
                    # Add the content of the 'Strategies' tab here

                TabbedPanelItem:
                    text: 'Portfolio'
                    size_hint_x: None
                    width: 800
                    # Add the content of the 'Portfolio' tab here