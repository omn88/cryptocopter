<CoinSniper>:
    orientation: 'vertical'
    BoxLayout:
        orientation: 'vertical'
        size_hint_y: None
        height: '150dp'  # Height for configuration controls

        BoxLayout:  # Main horizontal layout for configuration and buttons
            # Configuration section (left side)
            BoxLayout:
                orientation: 'vertical'
                size_hint_x: 0.75  # Give 75% of the space to configuration

                BoxLayout:  # First line of configuration
                    orientation: 'horizontal'
                    size_hint_y: None
                    height: '50dp'
                    spacing: 5
                    Label:
                        text: 'I want to '
                    Spinner:
                        id: action_input
                        values: ['BUY', 'SELL']
                        text: 'Choose Action'
                    Spinner:
                        id: symbol_input
                        values: ['BTCUSDT', 'ETHUSDT']
                        text: 'Choose Symbol'
                    Label:
                        text: ' with budget: '
                    TextInput:
                        id: budget_input
                        multiline: False
                        input_filter: 'float'

                BoxLayout:  # Second line: Pricing information
                    orientation: 'horizontal'
                    size_hint_y: None
                    height: '50dp'
                    spacing: 5
                    Label:
                        text: 'Price Low: '
                    TextInput:
                        id: price_low_input
                        multiline: False
                        input_filter: 'float'
                    Label:
                        text: 'Price High: '
                    TextInput:
                        id: price_high_input
                        multiline: False
                        input_filter: 'float'

                BoxLayout:  # Third line: Advanced trading options
                    orientation: 'horizontal'
                    size_hint_y: None
                    height: '50dp'
                    spacing: 5
                    Label:
                        text: 'Trigger orders (in %): '
                    TextInput:
                        id: trigger_orders_input
                        multiline: False
                        input_filter: 'float'
                    Label:
                        text: 'Mode: '
                    Spinner:
                        id: mode_input
                        values: ['DCA', 'SINGLE']
                        text: 'Choose Mode'

            # Right section for action buttons
            BoxLayout:
                orientation: 'vertical'
                size_hint_x: 0.25
                Button:
                    text: 'Add Record'
                    size_hint_y: None
                    height: '50dp'
                    on_release: root.add_record(symbol_input.text, side_input.text, price_low_input.text, price_high_input.text, budget_input.text)
                Button:
                    text: 'Remove Record'
                    size_hint_y: None
                    height: '50dp'
                    on_release: root.remove_record()

    # Bottom section with tabbed panels for records
    BoxLayout:
        id: bottom_section
        orientation: 'vertical'
        size_hint_y: 1  # Allow this to take the remaining space

        TabbedPanel:
            do_default_tab: False
            size_hint_y: 1  # Ensure tabs take full vertical space available

            TabbedPanelItem:
                text: 'Active Records'
                BoxLayout:
                    orientation: "vertical"
                    RecycleView:
                        id: active_records_list
                        data: root.active_records
                        viewclass: 'RecordListItem'

            TabbedPanelItem:
                text: 'Closed Records'
                BoxLayout:
                    orientation: "vertical"
                    RecycleView:
                        id: closed_records_list
                        data: root.closed_records
                        viewclass: 'RecordListItem'
