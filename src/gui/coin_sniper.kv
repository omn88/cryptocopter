<CoinSniper>:
    orientation: 'vertical'
    BoxLayout:
        orientation: 'vertical'
        size_hint_y: None
        height: '150dp'  # Height for configuration controls

        # Main horizontal layout for configuration, empty space, and buttons
        BoxLayout:
            orientation: 'horizontal'

            # Configuration section (left side) - now using only 50% of the width
            BoxLayout:
                orientation: 'vertical'
                size_hint_x: 0.6  # Reduced to 50% of the horizontal space

                # First line: Basic trading options
                BoxLayout:
                    orientation: 'horizontal'
                    size_hint_y: None
                    height: '50dp'
                    spacing: 5
                    Label:
                        text: 'I want to '
                    Spinner:
                        id: action_input
                        values: ['BUY', 'SELL']
                        text: 'Choose Action'
                    Spinner:
                        id: symbol_input
                        values: ['BTCUSDT', 'ETHUSDT']
                        text: 'Choose Symbol'
                    Label:
                        text: ' with budget: '
                    TextInput:
                        id: budget_input
                        multiline: False
                        input_filter: 'float'

                # Second line: Pricing information
                BoxLayout:
                    orientation: 'horizontal'
                    size_hint_y: None
                    height: '50dp'
                    Label:
                        text: 'Price Low: '
                    TextInput:
                        id: price_low_input
                        multiline: False
                        input_filter: 'float'
                    Label:
                        text: 'Price High: '
                    TextInput:
                        id: price_high_input
                        multiline: False
                        input_filter: 'float'

                # Third line: Advanced trading options
                BoxLayout:
                    orientation: 'horizontal'
                    size_hint_y: None
                    height: '50dp'
                    Label:
                        text: 'Trigger orders (in %): '
                    TextInput:
                        id: trigger_orders_input
                        multiline: False
                        input_filter: 'float'
                    Label:
                        text: 'Mode: '
                    Spinner:
                        id: mode_input
                        values: ['DCA', 'SINGLE']
                        text: 'Choose Mode'

            # Empty space to fill 25% of the width
            BoxLayout:
                size_hint_x: 0.2

            # Right section for action buttons - maintains 25% width
            BoxLayout:
                orientation: 'vertical'
                size_hint_x: 0.2
                Button:
                    text: 'Add Record'
                    size_hint_y: None
                    height: '50dp'
                    on_release: root.add_record(symbol_input.text, side_input.text, price_low_input.text, price_high_input.text, budget_input.text)
                Button:
                    text: 'Remove Record'
                    size_hint_y: None
                    height: '50dp'
                    on_release: root.remove_record()

    # Bottom section with tabbed panels for records
    BoxLayout:
        id: bottom_section
        orientation: 'vertical'
        size_hint_y: 1  # Allow this to take the remaining space

        TabbedPanel:
            do_default_tab: False
            size_hint_y: 1  # Ensure tabs take full vertical space available

            TabbedPanelItem:
                text: 'Active Records'
                BoxLayout:
                    orientation: "vertical"
                    RecycleView:
                        id: active_records_list
                        data: root.active_records
                        viewclass: 'RecordListItem'

            TabbedPanelItem:
                text: 'Closed Records'
                BoxLayout:
                    orientation: "vertical"
                    RecycleView:
                        id: closed_records_list
                        data: root.closed_records
                        viewclass: 'RecordListItem'
